# ##################################################################
# FULBITO - MATCHMAKING DEPORTIVO APP
# .gitignore - Configuración de Archivos Ignorados para Git
# ##################################################################

# Dependencias (Node dependencies)
node_modules/
/jspm_packages/
.pnp
.pnp.js
.yarn/
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Compilación y Salidas (Build outputs)
.next/
out/
build/
dist/
/target/
.docusaurus/
.cache/

# Variables de entorno y Secretos (CRITICAL - Env and Secrets)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
*.env.local
supabase/functions/.env
.dev.vars

# Supabase Local Development
supabase/.temp/
supabase/.branches/

# Vercel & Turborepo
.vercel/
.turbo/

# Configuración de Editores e IDEs (Editor configs)
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.classpath
.project
.settings/
*.sublime-project
*.sublime-workspace

# Archivos del Sistema Operativo (OS / System files)
.DS_Store
.DS_Store?
._*
ehthumbs.db
Thumbs.db
Icon?
desktop.ini

# Logs de error y Diagnósticos (Logs and debug)
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
pnpm-debug.log*

# Caché de Herramientas de Desarrollo (Linter & TS caches)
.eslintcache
.stylelintcache
*.tsbuildinfo
next-env.d.ts
